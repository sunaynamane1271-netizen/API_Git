    {
      "name": "get AI",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const EXPECTED_STATUS_CODE = 200;",
              "const MAX_RESPONSE_TIME = 2000;",
              "const EXPECTED_PAGE = 1;",
              "const EXPECTED_PER_PAGE = 6;",
              "const EXPECTED_TOTAL = 12;",
              "const EXPECTED_TOTAL_PAGES = 2;",
              "const EXPECTED_DATA_LENGTH = 6;",
              "const EXPECTED_SUPPORT_URL = 'https://benhowdle.im/first-cto-playbook?utm_source=reqres&utm_medium=json&utm_campaign=referral';",
              "const EXPECTED_SUPPORT_TEXT = 'Become a better CTO. A playbook of painful stories and practical advice from a two-time startup CTO.';",
              "",
              "const EXPECTED_DATA = [",
              "    {",
              "        id: 1,",
              "        name: 'cerulean',",
              "        year: 2000,",
              "        color: '#98B2D1',",
              "        pantone_value: '15-4020'",
              "    },",
              "    {",
              "        id: 2,",
              "        name: 'fuchsia rose',",
              "        year: 2001,",
              "        color: '#C74375',",
              "        pantone_value: '17-2031'",
              "    },",
              "    {",
              "        id: 3,",
              "        name: 'true red',",
              "        year: 2002,",
              "        color: '#BF1932',",
              "        pantone_value: '19-1664'",
              "    },",
              "    {",
              "        id: 4,",
              "        name: 'aqua sky',",
              "        year: 2003,",
              "        color: '#7BC4C4',",
              "        pantone_value: '14-4811'",
              "    },",
              "    {",
              "        id: 5,",
              "        name: 'tigerlily',",
              "        year: 2004,",
              "        color: '#E2583E',",
              "        pantone_value: '17-1456'",
              "    },",
              "    {",
              "        id: 6,",
              "        name: 'blue turquoise',",
              "        year: 2005,",
              "        color: '#53B0AE',",
              "        pantone_value: '15-5217'",
              "    }",
              "];",
              "",
              "function validateStatusCode() {",
              "    pm.test('Status code is 200', function () {",
              "        pm.response.to.have.status(EXPECTED_STATUS_CODE);",
              "    });",
              "}",
              "",
              "function validateResponseTime() {",
              "    pm.test('Response time is within acceptable limit', function () {",
              "        pm.expect(pm.response.responseTime).to.be.below(MAX_RESPONSE_TIME);",
              "    });",
              "}",
              "",
              "function validateResponseBodyStructure(responseJson) {",
              "    pm.test('Response body has the expected structure', function () {",
              "        pm.expect(responseJson).to.be.an('object');",
              "        pm.expect(responseJson).to.have.property('page');",
              "        pm.expect(responseJson).to.have.property('per_page');",
              "        pm.expect(responseJson).to.have.property('total');",
              "        pm.expect(responseJson).to.have.property('total_pages');",
              "        pm.expect(responseJson).to.have.property('data');",
              "        pm.expect(responseJson).to.have.property('support');",
              "",
              "        pm.expect(responseJson.data).to.be.an('array');",
              "        pm.expect(responseJson.support).to.be.an('object');",
              "    });",
              "}",
              "",
              "function validateResponseBodyParameters(responseJson) {",
              "    pm.test('Response body top-level parameters match expected values', function () {",
              "        pm.expect(responseJson.page).to.eql(EXPECTED_PAGE);",
              "        pm.expect(responseJson.per_page).to.eql(EXPECTED_PER_PAGE);",
              "        pm.expect(responseJson.total).to.eql(EXPECTED_TOTAL);",
              "        pm.expect(responseJson.total_pages).to.eql(EXPECTED_TOTAL_PAGES);",
              "        pm.expect(responseJson.data.length).to.eql(EXPECTED_DATA_LENGTH);",
              "        pm.expect(responseJson.support.url).to.eql(EXPECTED_SUPPORT_URL);",
              "        pm.expect(responseJson.support.text).to.eql(EXPECTED_SUPPORT_TEXT);",
              "    });",
              "}",
              "",
              "function validateDataArrayParameters(responseJson) {",
              "    pm.test('Response body data array parameters match expected values by index', function () {",
              "        for (let index = 0; index < EXPECTED_DATA.length; index++) {",
              "            pm.expect(responseJson.data[index].id).to.eql(EXPECTED_DATA[index].id);",
              "            pm.expect(responseJson.data[index].name).to.eql(EXPECTED_DATA[index].name);",
              "            pm.expect(responseJson.data[index].year).to.eql(EXPECTED_DATA[index].year);",
              "            pm.expect(responseJson.data[index].color).to.eql(EXPECTED_DATA[index].color);",
              "            pm.expect(responseJson.data[index].pantone_value).to.eql(EXPECTED_DATA[index].pantone_value);",
              "        }",
              "    });",
              "}",
              "",
              "const responseJson = pm.response.json();",
              "",
              "validateStatusCode();",
              "validateResponseTime();",
              "validateResponseBodyStructure(responseJson);",
              "validateResponseBodyParameters(responseJson);",
              "validateDataArrayParameters(responseJson);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
