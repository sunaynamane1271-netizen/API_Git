      "name": "Post data Driven_csv",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "var requestBody = pm.request.body.raw; \r",
              "requestBody = JSON.parse(requestBody)\r",
              "console.log(requestBody);\r",
              "var req_name=requestBody.name;\r",
              "var req_job = requestBody.job;\r",
              "var expected_Date = new Date().toISOString();\r",
              "expected_Date = expected_Date.substring(0, 11);\r",
              "console.log(expected_Date);\r",
              "\r",
              "var responseBody = pm.response.json();\r",
              "var res_name = responseBody.name;\r",
              "var res_job = responseBody.job;\r",
              "var res_id = responseBody.id;\r",
              "var res_createdAt = responseBody.createdAt;\r",
              "var res_meta_powered_by = responseBody._meta.powered_by;\r",
              "var res_cta_label = responseBody._meta.cta.label;\r",
              "\r",
              "pm.test(\"Response body parameter : Name\", function () {\r",
              "    pm.expect(res_name).to.eql(req_name);  \r",
              "})\r",
              "pm.test(\"Response body parameter : Job\", function () {\r",
              "    pm.expect(res_job).to.eql(req_job);\r",
              "})\r",
              "pm.test(\"Response body parameter : Id\", function () {\r",
              "    pm.expect(res_id).length.greaterThan(0);\r",
              "    pm.expect(parseInt(res_id)).to.not.null;\r",
              "    pm.expect(parseInt(res_id)).to.greaterThan(0);\r",
              "})\r",
              "pm.test(\"Response body parameter : Expected Date\", function () {\r",
              "    pm.expect(res_createdAt.substring(0, 11)).to.eql(expected_Date);  \r",
              "})\r",
              "pm.test(\"Response body parameter : Expected Date\", function () {\r",
              "    pm.expect(res_createdAt.substring(0, 11)).to.eql(expected_Date);  \r",
              "})\r",
              ""
            ],
